{
  "name": "lean-extensions",
  "displayName": "Lean Extensions",
  "version": "0.1.0",
  "description": "Keep your browser lean and fast. Manage extensions, collect links, capture pages.",
  "author": "aloe",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@plasmohq/storage": "^1.15.0",
    "plasmo": "0.90.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@plasmohq/prettier-plugin-sort-imports": "4.0.1",
    "@types/chrome": "^0.0.287",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitest/coverage-v8": "^2.1.9",
    "autoprefixer": "^10.4.20",
    "happy-dom": "^20.8.9",
    "postcss": "^8.5.10",
    "prettier": "3.2.5",
    "tailwindcss": "^3.4.17",
    "typescript": "5.7.3",
    "vitest": "^2.1.9"
  },
  "manifest": {
    "permissions": [
      "management",
      "tabs",
      "activeTab",
      "storage",
      "debugger",
      "clipboardWrite",
      "clipboardRead",
      "downloads",
      "contextMenus",
      "cookies",
      "browsingData",
      "alarms",
      "webNavigation"
    ],
    "host_permissions": [
      "https://notebooklm.google.com/*",
      "<all_urls>"
    ],
    "commands": {
      "toggle-all-off": {
        "suggested_key": {
          "default": "Alt+Shift+D"
        },
        "description": "Disable all extensions (except pinned)"
      },
      "toggle-all-on": {
        "suggested_key": {
          "default": "Alt+Shift+E"
        },
        "description": "Enable all extensions"
      },
      "save-link": {
        "suggested_key": {
          "default": "Alt+Shift+S"
        },
        "description": "Save current page link"
      },
      "open-dashboard": {
        "suggested_key": {
          "default": "Alt+Shift+L"
        },
        "description": "Open Lean Extensions dashboard"
      },
      "toggle-pip": {
        "description": "Toggle picture-in-picture for the active video. No default shortcut — Chrome caps suggested_key at 4 commands per extension; assign manually in chrome://extensions/shortcuts if you want a hotkey."
      }
    }
  }
}
